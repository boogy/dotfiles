// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  // {
  //   "context": "Workspace",
  //   "bindings": {
  //     "shift shift": "file_finder::Toggle",
  //   },
  // },
  // {
  //   "context": "Editor && vim_mode == insert",
  //   "bindings": {
  //     // "j k": "vim::NormalBefore"
  //   },
  // },

  // Focus terminal if in editor
  {
    "context": "Editor",
    "bindings": {
      // "cmd-shift-j": "terminal_panel::ToggleFocus",
      "cmd-j": "terminal_panel::ToggleFocus",
    },
  },

  // Set terminal to full zoom
  {
    "context": "Terminal || Editor || Workspace",
    "bindings": {
      "cmd-shift-j": "workspace::ToggleZoom",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-+": ["zed::IncreaseBufferFontSize", { "persist": false }],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-g": "git_panel::ToggleFocus",
    },
  },
  {
    "bindings": {
      "cmd-shift-z": "zed::Zoom",
    },
  },
  // Shift focus to editor from terminal
  {
    "context": "Terminal",
    "bindings": {
      "cmd-g e": "terminal_panel::ToggleFocus",
    },
  },
  // Shift focus to terminal from editor
  {
    "context": "Editor",
    "bindings": {
      "cmd-g e": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-k l": "language_selector::Toggle",
    },
  },
  // {
  //   "context": "Editor",
  //   "bindings": {
  //     "cmd-k f": "editor::Format",
  //   },
  // },

  // Replicate tmux movements
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-x h": "workspace::ActivatePaneLeft",
      "ctrl-x l": "workspace::ActivatePaneRight",
      "ctrl-x j": "workspace::ActivatePaneDown",
      "ctrl-x k": "workspace::ActivatePaneUp",

      "alt-shift-h": "workspace::ActivatePaneLeft",
      "alt-shift-l": "workspace::ActivatePaneRight",
      "alt-shift-j": "workspace::ActivatePaneDown",
      "alt-shift-k": "workspace::ActivatePaneUp",

      // Global "back to editor" button
      "ctrl-alt-enter": "workspace::ActivateNextPane",

      // Open recent
      "ctrl-r": "projects::OpenRecent",
    },
  },
  // Close active tab immediately
  {
    "bindings": {
      "cmd-w": ["pane::CloseActiveItem", { "close_pinned": false }],
    },
  },
  // Git
  {
    "context": "GitPanel",
    "bindings": {
      "ctrl-z": "git::Uncommit",
      "ctrl-delete": "git::RestoreTrackedFiles",
      "ctrl-s": "git::Fetch",
    },
  },
  // Pane
  {
    "context": "Pane",
    "bindings": {
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-tab": "pane::ActivateNextItem",
    },
  },
  // Project panel
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-n": "project_panel::NewFile",
      "ctrl-shift-n": "project_panel::NewDirectory",
    },
  },
]
