# ── Terraform sub-command completions (for run -- <cmd> args) ────────────

__tf_statelist() {
  compadd $(terraform state list 2>/dev/null)
}

__tf_apply() {
  _arguments -s \
    '-auto-approve[Skip interactive approval.]' \
    '-backup=[(path) Path to backup state file.]:file:_files' \
    '-compact-warnings[Show compact warnings.]' \
    '-lock=[(true) Lock the state file.]:lock:(true false)' \
    '-lock-timeout=[(0s) Duration to retry a state lock.]' \
    '-input=[(true) Ask for input for variables.]' \
    '-no-color[Disable color output.]' \
    '-parallelism=[(10) Limit parallel resource operations.]' \
    '-refresh=[(true) Update state prior to checking for differences.]' \
    '-state=[(terraform.tfstate) Path to state file.]:file:_files' \
    '-state-out=[(path) Path to write state.]:file:_files' \
    '*-target=[(resource) Resource to target.]:target:__tf_statelist' \
    '*-var=[Set a variable.]:var:' \
    '*-var-file=[Set variables from file.]:file:_files -g "*.tfvars{,.json}"'
}

__tf_plan() {
  _arguments -s \
    '-compact-warnings[Show compact warnings.]' \
    '-destroy[Generate a destroy plan.]' \
    '-detailed-exitcode[Return detailed exit codes.]' \
    '-input=[(true) Ask for input for variables.]' \
    '-lock=[(true) Lock the state file.]:lock:(true false)' \
    '-lock-timeout=[(0s) Duration to retry a state lock.]' \
    '-no-color[Disable color output.]' \
    '-out=[(path) Write plan file to path.]' \
    '-parallelism=[(10) Limit concurrent operations.]' \
    '-refresh=[(true) Update state prior to checking.]' \
    '-state=[(statefile) Path to state file.]:file:_files' \
    '*-target=[(resource) Resource to target.]:target:__tf_statelist' \
    '*-var=[Set a variable.]:var:' \
    '*-var-file=[Set variables from file.]:file:_files -g "*.tfvars{,.json}"'
}

__tf_destroy() {
  _arguments -s \
    '-auto-approve[Skip interactive approval.]' \
    '-backup=[(path) Path to backup state file.]:file:_files' \
    '-compact-warnings[Show compact warnings.]' \
    '-lock=[(true) Lock the state file.]:lock:(true false)' \
    '-lock-timeout=[(0s) Duration to retry a state lock.]' \
    '-no-color[Disable color output.]' \
    '-parallelism=[(10) Limit concurrent operations.]' \
    '-refresh=[(true) Update state prior to checking.]' \
    '-state=[(terraform.tfstate) Path to state file.]:file:_files' \
    '-state-out=[(path) Path to write state.]:file:_files' \
    '*-target=[(resource) Resource to target.]:target:__tf_statelist' \
    '*-var=[Set a variable.]:var:' \
    '*-var-file=[Set variables from file.]:file:_files -g "*.tfvars{,.json}"'
}

__tf_init() {
  _arguments -s \
    '-backend=[(true) Configure the backend.]' \
    '-backend-config=[Backend configuration.]:config:' \
    '-force-copy[Suppress prompts about copying state data.]' \
    '-from-module=[(SOURCE) Copy module contents before init.]:source:' \
