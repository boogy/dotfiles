# ── Main dispatch ────────────────────────────────────────────────────────

_arguments -C '*:: :->command'

if (( CURRENT == 1 )); then
  _describe -t commands "terragrunt command" _tg_cmds
  return
fi

case "$words[1]" in
  run)        __tg_run ;;
  stack)      __tg_stack ;;
  exec)       __tg_exec ;;
  backend)    __tg_backend ;;
  find|fd)    __tg_find ;;
  list|ls)    __tg_list ;;
  dag)        __tg_dag ;;
  hcl)        __tg_hcl ;;
  info)       __tg_info ;;
  render)     __tg_render ;;
  catalog)    __tg_catalog ;;
  scaffold)   __tg_scaffold ;;
  # OpenTofu/Terraform shortcuts (same as run -- <cmd>)
  apply)      __tf_apply ;;
  plan)       __tf_plan ;;
  destroy)    __tf_destroy ;;
  init)       __tf_init ;;
  output)     __tf_output ;;
  state)      __tf_state ;;
  workspace)  __tf_workspace ;;
  show)
    _arguments -s \
      '-json[Output in machine-readable JSON.]' \
      '-no-color[Disable color output.]'
    ;;
  validate)
    _arguments -s \
      '-no-color[Disable color output.]' \
      '-json[Produce JSON output.]' \
      ':dir:_directories'
    ;;
  refresh)
    _arguments -s \
      '-backup=[(path) Backup state file.]:file:_files' \
      '-compact-warnings[Show compact warnings.]' \
      '-input=[(true) Ask for input.]' \
      '-lock=[(true) Lock the state file.]:lock:(true false)' \
      '-lock-timeout=[(0s) Duration to retry state lock.]' \
      '-no-color[Disable color output.]' \
      '-state=[(path) Path to state file.]:file:_files' \
      '-state-out=[(path) Path to write state.]:file:_files' \
      '*-target=[(resource) Resource to target.]:target:__tf_statelist' \
      '*-var=[Set a variable.]:var:' \
      '*-var-file=[Set variables from file.]:file:_files -g "*.tfvars{,.json}"'
    ;;
  import)
    _arguments -s \
      '-backup=[(path) Backup state file.]:file:_files' \
      '-config=[(path) Path to config files.]:dir:_directories' \
      '-allow-missing-config[Allow import with no resource config.]' \
      '-input=[(true) Ask for input.]' \
      '-lock=[(true) Lock the state file.]:lock:(true false)' \
      '-lock-timeout=[(0s) Duration to retry state lock.]' \
      '-no-color[Disable color output.]' \
      '-state=[(PATH) Path to state file.]:file:_files' \
      '-state-out=[(PATH) Path to write state.]:file:_files' \
      '*-var=[Set a variable.]:var:' \
      '*-var-file=[Set variables from file.]:file:_files -g "*.tfvars{,.json}"'
    ;;
  force-unlock)
    _arguments -s \
      '-force[Do not ask for confirmation.]'
    ;;
esac
